  calculateSovereigntyMetrics(userResponses) {
    // Input format check: Expects object matching item codes to integers 1-7
    // Example: { "SSS-IA-01": 5, "SSS-DR-01": 6, ... }
    
    const subTotals = { InteroceptiveAwareness: 0, AutonomicDownRegulation: 0, ChoicePreservation: 0 };
    const maxDimensionScore = 42; // 6 items * 7 points
    const minDimensionScore = 6;  // 6 items * 1 point
    const range = maxDimensionScore - minDimensionScore;

    for (const [itemCode, value] of Object.entries(userResponses)) {
      const parsedValue = Math.min(Math.max(parseInt(value, 10), 1), 7);
      
      if (itemCode.includes("-IA-")) subTotals.InteroceptiveAwareness += parsedValue;
      else if (itemCode.includes("-DR-")) subTotals.AutonomicDownRegulation += parsedValue;
      else if (itemCode.includes("-CP-")) subTotals.ChoicePreservation += parsedValue;
    }

    // Convert to normalized 0-100 dimensional indices
    const normalizedMetrics = {
      interoceptive_awareness_index:   Math.round(((subTotals.InteroceptiveAwareness - minDimensionScore) / range) * 100),
      autonomic_down_regulation_index: Math.round(((subTotals.AutonomicDownRegulation - minDimensionScore) / range) * 100),
      choice_preservation_index:       Math.round(((subTotals.ChoicePreservation - minDimensionScore) / range) * 100)
    };

    // Calculate total composite score
    const aggregateRaw = subTotals.InteroceptiveAwareness + subTotals.AutonomicDownRegulation + subTotals.ChoicePreservation;
    const totalMax = 126;
    const totalMin = 18;
    const compositeSovereigntyScore = Math.round(((aggregateRaw - totalMin) / (totalMax - totalMin)) * 100);

    return {
      timestamp_utc: new Date().toISOString(),
      construct_notice: "PROPOSED CONSTRUCT METRICS: This scale measures self-reported psychophysiological resilience and behavioral decoupling parameters. It is currently under independent empirical validation.",
      composite_sovereignty_score: compositeSovereigntyScore,
      dimensional_breakdown: normalizedMetrics,
      clinical_escalation_flag: compositeSovereigntyScore < 30 ? "RED_ZONE: Immediate professional clinical escalation recommended. High autonomic instability." : "GREEN_COMPLIANT"
    };
  }
}

