async function refreshTelemetryMatrix() {
    const selectedGroup = $wnd("#groupFilter").value;
    const selectedTimepoint = $wnd("#timeFilter").value;

    console.log(`[QUERY_RUN] Fetching Telemetry for Cohort: ${selectedGroup} // Time Point: ${selectedTimepoint}`);

    try {
        // Initialize base query constraint matrix on secure data collection node
        let telemetryQuery = wixData.query("PsrsesTelemetryDataset")
            .eq("timepoint_anchor", selectedTimepoint);

        if (selectedGroup !== "ALL") {
            telemetryQuery = telemetryQuery.eq("assigned_experimental_group", selectedGroup);
        }

        const queryResults = await telemetryQuery.limit(200).find();
        const records = queryResults.items;

        if (records.length > 0) {
            // Run processing loop to determine mathematical subscale means
            const averages = calculateSubscaleMeans(records);
            
            // Push calculated values directly to front-end layout displays
            $wnd("#iaeMeanDisplay").text = averages.iaeMean.toFixed(1);
            $wnd("#pdrMeanDisplay").text = averages.pdrMean.toFixed(1);
            $wnd("#srdMeanDisplay").text = averages.srdMean.toFixed(1);

            // Transmit cleaned metric payloads to chart component engine
            renderCohortChart(records, selectedGroup);
        } else {
            console.warn("[WARNING] Empty payload returned from collection query criteria.");
            resetDisplayElements();
        }
    } catch (error) {
        console.error(`[CRITICAL EXCEPTION] Failed to execute telemetry routing pipeline: ${error.message}`);
    }
}

function calculateSubscaleMeans(items) {
    let sumIAE = 0, sumPDR = 0, sumSRD = 0;
    const totalCount = items.length;

    items.forEach(record => {
        sumIAE += record.interoceptive_awareness_efficacy_index || 0;
        sumPDR += record.perceived_autonomic_down_regulation_index || 0;
        sumSRD += record.perceived_stimulus_response_decoupling || 0;
    });

    return {
        iaeMean: sumIAE / totalCount,
        pdrMean: sumPDR / totalCount,
        srdMean: sumSRD / totalCount
    };
}

function renderCohortChart(dataset, groupFilter) {
    // Collect and format database arrays for the HTML component chart injector
    const payload = dataset.map(item => ({
        uuid: item.participant_uuid,
        group: item.assigned_experimental_group,
        metrics: [
            item.interoceptive_awareness_efficacy_index,
            item.perceived_autonomic_down_regulation_index,
            item.perceived_stimulus_response_decoupling
        ]
    }));

    // Post messaging vector payload directly to the background custom chart canvas node
    $wnd("#htmlChartContainer").postMessage({
        action: "UPDATE_CHART_DATA",
        groupContext: groupFilter,
        telemetryArray: payload
    });
}

function resetDisplayElements() {
    $wnd("#iaeMeanDisplay").text = "--.-";
    $wnd("#pdrMeanDisplay").text = "--.-";
    $wnd("#srdMeanDisplay").text = "--.-";
}

