/**
 * ROSS OS v0.2-CANON: FANTASY FAMILY INVENTORY (FFI) SCORING ENGINE
 * Document ID: FFI-ENGINE-2026-V1
 * Verification Node: Active // Psychometric Quantizer
 */

class FantasyFamilyInventoryEngine {
  constructor() {
    this.dimensionKeys = ["Connection", "Novelty", "Agency", "Security", "Identity", "Transcendence"];
  }

  processInventoryResponses(userResponses) {
    // Expects userResponses to be an object mapping item IDs to integer values 1-7
    // Example: { "CN-01": 7, "CN-02": 6, "NV-01": 2, ... }
    
    const rawScores = { Connection: 0, Novelty: 0, Agency: 0, Security: 0, Identity: 0, Transcendence: 0 };
    const maxPossibleRawPerDimension = 28; // 4 items * 7 points
    const minPossibleRawPerDimension = 4;  // 4 items * 1 point
    const range = maxPossibleRawPerDimension - minPossibleRawPerDimension;

    // Aggregate raw values across orthogonal axes
    for (const [itemCode, value] of Object.entries(userResponses)) {
      const sanitizedValue = Math.min(Math.max(parseInt(value, 10), 1), 7);
      
      if (itemCode.startsWith("CN")) rawScores.Connection += sanitizedValue;
      else if (itemCode.startsWith("NV")) rawScores.Novelty += sanitizedValue;
      else if (itemCode.startsWith("AG")) rawScores.Agency += sanitizedValue;
      else if (itemCode.startsWith("SC")) rawScores.Security += sanitizedValue;
      else if (itemCode.startsWith("ID")) rawScores.Identity += sanitizedValue;
      else if (itemCode.startsWith("TR")) rawScores.Transcendence += sanitizedValue;
    }

    // Convert to 0-100 normalized dimensional percentiles
    const dimensionalProfile = {};
    for (const dimension of this.dimensionKeys) {
      const raw = rawScores[dimension];
      const normalizedScore = ((raw - minPossibleRawPerDimension) / range) * 100;
      dimensionalProfile[dimension] = Math.round(normalizedScore);
    }

    // Determine target behavioral redirect module based on profile geometry
    const primaryVector = this._calculateTargetRouting(dimensionalProfile);

    return {
      timestamp_utc: new Date().toISOString(),
      disclaimer: "METRIC PROFILE NOTICE: This telemetry reflects recurring motivational and imaginative themes under a non-diagnostic framework. It is intended strictly for behavioral self-regulation and strategic routing.",
      axis_scores: {
        connection_percentile:    dimensionalProfile.Connection,
        novelty_percentile:       dimensionalProfile.Novelty,
        agency_percentile:        dimensionalProfile.Agency,
        security_percentile:      dimensionalProfile.Security,
        identity_percentile:      dimensionalProfile.Identity,
        transcendence_percentile: dimensionalProfile.Transcendence
      },
      system_routing: primaryVector
    };
  }

  _calculateTargetRouting(profile) {
    // Sort dimensions to isolate the highest active motivational driver
    const sorted = Object.entries(profile).sort((a, b) => b[1] - a[1]);
    const dominantDimension = sorted[0][0];

    // Algorithmic mapping of psychological deficits to high-agency modules
    const routingMap = {
      Connection:    { target_module: "MEDIA", action: "Execute network protocol rectification. Align communication channels." },
      Novelty:       { target_module: "CREATIVE", action: "Form Study Activation. Channel high-stimulus drive into aesthetic architecture." },
      Agency:        { target_module: "BUSINESS", action: "Deploy growth architecture systems. Maximize professional structural agency." },
      Security:      { target_module: "DEVELOPMENT", action: "System infrastructure hardening. Execute 45-minute isolated code sprint." },
      Identity:      { target_module: "CREATIVE", action: "Core narrative re-framing. Document Personal Constitution value fields." },
      Transcendence: { target_module: "DEVELOPMENT", action: "Engage somatic down-regulation. Box Breathing sequence initialization." }
    };

    return routingMap[dominantDimension];
  }
}

