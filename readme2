    for (let i = 0; i < this.movingHeartbeatIntervals.length - 1; i++) {
      const difference = this.movingHeartbeatIntervals[i + 1] - this.movingHeartbeatIntervals[i];
      squaredDifferencesSum += Math.pow(difference, 2);
    }

    const meanSquaredDifference = squaredDifferencesSum / (this.movingHeartbeatIntervals.length - 1);
    const rmssd = Math.sqrt(meanSquaredDifference);

    return parseFloat(rmssd.toFixed(2));
  }
